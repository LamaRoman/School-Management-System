generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ──────────────────────────────────────────────

enum StudentStatus {
  ACTIVE
  GRADUATED
  TRANSFERRED_OUT
  RETAINED
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  ACCOUNTANT
  TEACHER
  STUDENT
  PARENT
}

enum AttendanceStatus {
  PRESENT
  ABSENT
}

// ─── SCHOOL ─────────────────────────────────────────────

model School {
  id        String   @id @default(cuid())
  name      String
  nameNp    String?  @map("name_np")
  code      String?  @unique           // Short receipt prefix e.g. "GHS", "SPS"
  address   String?
  phone     String?
  email     String?
  logo      String?
  estdYear  String?  @map("estd_year")
  motto     String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  reportCardSettings ReportCardSettings?
  receiptCounter     ReceiptCounter?
  users              User[]
  academicYears      AcademicYear[]
  teachers           Teacher[]
  feeCategories      FeeCategory[]
  examRooms          ExamRoom[]

  @@map("schools")
}

// ─── ACADEMIC YEAR ──────────────────────────────────────

model AcademicYear {
  id        String   @id @default(cuid())
  schoolId  String   @map("school_id")
  yearBS    String   @map("year_bs")
  startDate String?  @map("start_date")
  endDate   String?  @map("end_date")
  isActive  Boolean  @default(false) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  school           School         @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  grades           Grade[]
  examTypes        ExamType[]
  marks            Mark[]
  results          ConsolidatedResult[]
  attendances      Attendance[]
  dailyAttendances DailyAttendance[]
  observationResults ObservationResult[]
  seatAllocations SeatAllocation[]
  feeStructures      FeeStructure[]
  studentFeeOverrides StudentFeeOverride[]
  feePayments        FeePayment[]
  homeworks      Homework[]
  admissions     Admission[]

  @@unique([yearBS, schoolId])
  @@map("academic_years")
}

// ─── GRADE (Nursery, LKG, UKG, I–X) ────────────────────

model Grade {
  id             String       @id @default(cuid())
  name           String
  displayOrder   Int          @map("display_order")
  academicYearId String       @map("academic_year_id")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  academicYear    AcademicYear  @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  sections        Section[]
  subjects        Subject[]
  gradingPolicies GradingPolicy[]
  results         ConsolidatedResult[]
  observationCategories ObservationCategory[]
  examRoutines   ExamRoutine[]
  feeStructures  FeeStructure[]
  notices        Notice[]
  admissions     Admission[]

  @@unique([name, academicYearId])
  @@map("grades")
}

// ─── SECTION ────────────────────────────────────────────

model Section {
  id        String   @id @default(cuid())
  name      String
  gradeId   String   @map("grade_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  grade    Grade              @relation(fields: [gradeId], references: [id], onDelete: Cascade)
  students Student[]
  teachers TeacherAssignment[]
  homeworks      Homework[]

  @@unique([name, gradeId])
  @@map("sections")
}

// ─── SUBJECT ────────────────────────────────────────────

model Subject {
  id                 String   @id @default(cuid())
  name               String
  nameNp             String?  @map("name_np")
  fullTheoryMarks    Int      @map("full_theory_marks")
  fullPracticalMarks Int      @default(0) @map("full_practical_marks")
  passMarks          Int      @map("pass_marks")
  isOptional         Boolean  @default(false) @map("is_optional")
  displayOrder       Int      @default(0) @map("display_order")
  gradeId            String   @map("grade_id")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  grade              Grade    @relation(fields: [gradeId], references: [id], onDelete: Cascade)
  marks              Mark[]
  teacherAssignments TeacherAssignment[]
  examRoutines   ExamRoutine[]
  homeworks      Homework[]

  @@unique([name, gradeId])
  @@map("subjects")
}

// ─── EXAM TYPE ──────────────────────────────────────────

model ExamType {
  id             String       @id @default(cuid())
  name           String
  displayOrder   Int          @default(0) @map("display_order")
  academicYearId String       @map("academic_year_id")
  paperSize      String       @default("A5") @map("paper_size")
  showRank       Boolean      @default(true) @map("show_rank")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  academicYear    AcademicYear  @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  marks           Mark[]
  gradingPolicies GradingPolicy[]
  observationResults ObservationResult[]
  examRoutines   ExamRoutine[]
  seatAllocations SeatAllocation[]
  feeStructures  FeeStructure[]

  @@unique([name, academicYearId])
  @@map("exam_types")
}

// ─── GRADING POLICY (Weightage) ─────────────────────────

model GradingPolicy {
  id               String   @id @default(cuid())
  examTypeId       String   @map("exam_type_id")
  gradeId          String   @map("grade_id")
  weightagePercent Float    @map("weightage_percent")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  examType ExamType @relation(fields: [examTypeId], references: [id], onDelete: Cascade)
  grade    Grade    @relation(fields: [gradeId], references: [id], onDelete: Cascade)

  @@unique([examTypeId, gradeId])
  @@map("grading_policies")
}

// ─── STUDENT ────────────────────────────────────────────

model Student {
  id            String   @id @default(cuid())
  name          String
  nameNp        String?  @map("name_np")
  dateOfBirth   String?  @map("date_of_birth")
  rollNo        Int?     @map("roll_no")
  symbolNumber  String?  @map("symbol_number")
  gender        String?
  fatherName    String?  @map("father_name")
  motherName    String?  @map("mother_name")
  guardianName  String?  @map("guardian_name")
  guardianPhone String?  @map("guardian_phone")
  address       String?
  photo         String?
  sectionId     String   @map("section_id")
  isActive      Boolean  @default(true) @map("is_active")
  status        StudentStatus @default(ACTIVE)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  section          Section           @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  marks            Mark[]
  results          ConsolidatedResult[]
  attendances      Attendance[]
  dailyAttendances DailyAttendance[]
  user             User?
  observationResults ObservationResult[]
  seatAllocations SeatAllocation[]
  feeOverrides    StudentFeeOverride[]
  feePayments     FeePayment[]
  parentLinks    ParentStudent[]


  @@unique([rollNo, sectionId])
  @@map("students")
}

// ─── TEACHER ────────────────────────────────────────────

model Teacher {
  id        String   @id @default(cuid())
  schoolId  String   @map("school_id")
  name      String
  nameNp    String?  @map("name_np")
  phone     String?
  email     String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  school      School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  assignments TeacherAssignment[]
  user        User?

  @@map("teachers")
}

// ─── TEACHER ASSIGNMENT ─────────────────────────────────

model TeacherAssignment {
  id             String    @id @default(cuid())
  teacherId      String    @map("teacher_id")
  sectionId      String    @map("section_id")
  subjectId      String?   @map("subject_id")
  isClassTeacher Boolean   @default(false) @map("is_class_teacher")
  isTemporary    Boolean   @default(false) @map("is_temporary")
  expiresAt      DateTime? @map("expires_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @default(now()) @map("updated_at")

  teacher Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  section Section  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  subject Subject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)

  @@unique([teacherId, sectionId, subjectId])
  @@map("teacher_assignments")
}

// ─── USER (Auth) ────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  schoolId  String?  @map("school_id")
  email     String   @unique
  password  String
  role      UserRole
  studentId String?  @unique @map("student_id")
  teacherId String?  @unique @map("teacher_id")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  school         School?  @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  student Student? @relation(fields: [studentId], references: [id], onDelete: SetNull)
  teacher Teacher? @relation(fields: [teacherId], references: [id], onDelete: SetNull)
  parentLinks    ParentStudent[] @relation("ParentLinks")
  notices        Notice[]
  homeworks      Homework[]
  admissions     Admission[]
  auditLogs      AuditLog[]
  @@map("users")
}

// ─── MARK ───────────────────────────────────────────────

model Mark {
  id             String       @id @default(cuid())
  studentId      String       @map("student_id")
  subjectId      String       @map("subject_id")
  examTypeId     String       @map("exam_type_id")
  academicYearId String       @map("academic_year_id")
  theoryMarks    Float?       @map("theory_marks")
  practicalMarks Float?       @default(0) @map("practical_marks")
  isAbsent       Boolean      @default(false) @map("is_absent")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  student      Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject      Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  examType     ExamType     @relation(fields: [examTypeId], references: [id], onDelete: Cascade)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)

  @@unique([studentId, subjectId, examTypeId, academicYearId])
  @@map("marks")
}

// ─── CONSOLIDATED RESULT ────────────────────────────────

model ConsolidatedResult {
  id              String       @id @default(cuid())
  studentId       String       @map("student_id")
  academicYearId  String       @map("academic_year_id")
  gradeId         String       @map("grade_id")
  totalGpa        Float?       @map("total_gpa")
  totalPercentage Float?       @map("total_percentage")
  rank            Int?
  promoted        Boolean      @default(false)
  promotedTo      String?      @map("promoted_to")
  remarks         String?
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  student      Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  grade        Grade        @relation(fields: [gradeId], references: [id], onDelete: Cascade)

  @@unique([studentId, academicYearId])
  @@map("consolidated_results")
}

// ─── ATTENDANCE (Totals) ────────────────────────────────

model Attendance {
  id             String       @id @default(cuid())
  studentId      String       @map("student_id")
  academicYearId String       @map("academic_year_id")
  totalDays      Int          @default(0) @map("total_days")
  presentDays    Int          @default(0) @map("present_days")
  absentDays     Int          @default(0) @map("absent_days")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  student      Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)

  @@unique([studentId, academicYearId])
  @@map("attendances")
}

// ─── DAILY ATTENDANCE ───────────────────────────────────

model DailyAttendance {
  id             String           @id @default(cuid())
  studentId      String           @map("student_id")
  date           String
  status         AttendanceStatus @default(PRESENT)
  remarks        String?
  academicYearId String           @map("academic_year_id")
  markedById     String?          @map("marked_by_id")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @default(now()) @map("updated_at")

  student      Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)

  @@unique([studentId, date, academicYearId])
  @@map("daily_attendances")
}
// ─── REPORT CARD SETTINGS ───────────────────────────────

model ReportCardSettings {
  id                String  @id @default(cuid())
  schoolId          String  @unique @map("school_id")
  showPassMarks     Boolean @default(true) @map("show_pass_marks")
  showTheoryPrac    Boolean @default(true) @map("show_theory_prac")
  showPercentage    Boolean @default(false) @map("show_percentage")
  showGrade         Boolean @default(true) @map("show_grade")
  showGpa           Boolean @default(true) @map("show_gpa")
  showRank          Boolean @default(true) @map("show_rank")
  showAttendance    Boolean @default(true) @map("show_attendance")
  showRemarks       Boolean @default(true) @map("show_remarks")
  showPromotion     Boolean @default(true) @map("show_promotion")
  showNepaliName    Boolean @default(false) @map("show_nepali_name")
  logoPosition      String  @default("center") @map("logo_position")
  logoSize          String  @default("medium") @map("logo_size")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @default(now()) @map("updated_at")

  school            School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@map("report_card_settings")
}

// ─── GENERAL OBSERVATION ────────────────────────────────

model ObservationCategory {
  id           String   @id @default(cuid())
  name         String
  nameNp       String?  @map("name_np")
  gradeId      String   @map("grade_id")
  displayOrder Int      @default(0) @map("display_order")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @default(now()) @map("updated_at")

  grade   Grade               @relation(fields: [gradeId], references: [id], onDelete: Cascade)
  results ObservationResult[]

  @@unique([name, gradeId])
  @@map("observation_categories")
}

model ObservationResult {
  id             String   @id @default(cuid())
  studentId      String   @map("student_id")
  categoryId     String   @map("category_id")
  examTypeId     String   @map("exam_type_id")
  academicYearId String   @map("academic_year_id")
  grade          String   // A+, A, B+, B, C+, C, D+, D, E
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @default(now()) @map("updated_at")

  student      Student             @relation(fields: [studentId], references: [id], onDelete: Cascade)
  category     ObservationCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  examType     ExamType            @relation(fields: [examTypeId], references: [id], onDelete: Cascade)
  academicYear AcademicYear        @relation(fields: [academicYearId], references: [id], onDelete: Cascade)

  @@unique([studentId, categoryId, examTypeId, academicYearId])
  @@map("observation_results")
}

// ─── EXAM ROUTINE ───────────────────────────────────────

model ExamRoutine {
  id             String   @id @default(cuid())
  examTypeId     String   @map("exam_type_id")
  gradeId        String   @map("grade_id")
  subjectId      String   @map("subject_id")
  examDate       String   @map("exam_date")  // BS date string e.g. "2081/09/15"
  dayName        String?  @map("day_name")   // e.g. "Sunday", "Monday"
  startTime      String?  @map("start_time") // e.g. "11:00 AM"
  endTime        String?  @map("end_time")   // e.g. "2:00 PM"
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @default(now()) @map("updated_at")

  examType       ExamType @relation(fields: [examTypeId], references: [id], onDelete: Cascade)
  grade          Grade    @relation(fields: [gradeId], references: [id], onDelete: Cascade)
  subject        Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([examTypeId, gradeId, subjectId])
  @@map("exam_routines")
}

// ─── EXAM SEATING ───────────────────────────────────────

model ExamRoom {
  id           String   @id @default(cuid())
  schoolId     String   @map("school_id")
  name         String
  capacity     Int
  displayOrder Int      @default(0) @map("display_order")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @default(now()) @map("updated_at")

  school          School           @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  seatAllocations SeatAllocation[]

  @@map("exam_rooms")
}

model SeatAllocation {
  id             String   @id @default(cuid())
  examTypeId     String   @map("exam_type_id")
  academicYearId String   @map("academic_year_id")
  studentId      String   @map("student_id")
  roomId         String   @map("room_id")
  seatNumber     Int?     @map("seat_number")
  createdAt      DateTime @default(now()) @map("created_at")

  examType     ExamType     @relation(fields: [examTypeId], references: [id], onDelete: Cascade)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  student      Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  room         ExamRoom     @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([examTypeId, academicYearId, studentId])
  @@map("seat_allocations")
}
// ─── FEE MANAGEMENT ─────────────────────────────────────

model FeeCategory {
  id           String   @id @default(cuid())
  schoolId     String   @map("school_id")
  name         String
  description  String?
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @default(now()) @map("updated_at")

  school            School             @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  feeStructures     FeeStructure[]
  studentOverrides  StudentFeeOverride[]
  feePayments       FeePayment[]

  @@unique([name, schoolId])
  @@map("fee_categories")
}

model FeeStructure {
  id              String   @id @default(cuid())
  feeCategoryId   String   @map("fee_category_id")
  gradeId         String   @map("grade_id")
  academicYearId  String   @map("academic_year_id")
  amount          Float
  frequency       String   @default("MONTHLY")  // MONTHLY, ANNUAL, ONE_TIME, PER_EXAM
  examTypeId      String?  @map("exam_type_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @default(now()) @map("updated_at")

  feeCategory   FeeCategory  @relation(fields: [feeCategoryId], references: [id], onDelete: Cascade)
  grade         Grade        @relation(fields: [gradeId], references: [id], onDelete: Cascade)
  academicYear  AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  examType      ExamType?    @relation(fields: [examTypeId], references: [id], onDelete: SetNull)

  @@unique([feeCategoryId, gradeId, academicYearId, examTypeId])
  @@map("fee_structures")
}

model StudentFeeOverride {
  id              String   @id @default(cuid())
  studentId       String   @map("student_id")
  feeCategoryId   String   @map("fee_category_id")
  academicYearId  String   @map("academic_year_id")
  overrideAmount  Float    @map("override_amount")
  discountType    String   @default("FLAT") @map("discount_type")   // FLAT, PERCENTAGE
  discountPercent Float?   @map("discount_percent")
  reason          String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @default(now()) @map("updated_at")

  student       Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  feeCategory   FeeCategory  @relation(fields: [feeCategoryId], references: [id], onDelete: Cascade)
  academicYear  AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)

  @@unique([studentId, feeCategoryId, academicYearId])
  @@map("student_fee_overrides")
}

model FeePayment {
  id              String   @id @default(cuid())
  studentId       String   @map("student_id")
  feeCategoryId   String   @map("fee_category_id")
  academicYearId  String   @map("academic_year_id")
  amount          Float
  paidMonth       String?  @map("paid_month")     // e.g., "Baisakh", "Jestha" for monthly fees
  receiptNumber   String?  @map("receipt_number")
  paymentDate     String   @map("payment_date")   // BS date
  paymentMethod   String?  @map("payment_method")  // CASH, BANK, ONLINE
  remarks         String?
  createdAt       DateTime @default(now()) @map("created_at")
  deletedAt       DateTime? @map("deleted_at")

  student       Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  feeCategory   FeeCategory  @relation(fields: [feeCategoryId], references: [id], onDelete: Cascade)
  academicYear  AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)

  @@map("fee_payments")
}

// ─── NOTICE BOARD ───────────────────────────────────────

model Notice {
  id              String   @id @default(cuid())
  title           String
  content         String
  type            String   @default("GENERAL")     // GENERAL, EXAM, EVENT, HOLIDAY, FEE
  priority        String   @default("NORMAL")      // NORMAL, IMPORTANT, URGENT
  targetAudience  String   @default("ALL") @map("target_audience")  // ALL, TEACHERS, STUDENTS, PARENTS
  gradeId         String?  @map("grade_id")        // optional — for grade-specific notices
  publishDate     String   @map("publish_date")    // BS date
  expiryDate      String?  @map("expiry_date")     // BS date, null = no expiry
  isPublished     Boolean  @default(true) @map("is_published")
  isPinned        Boolean  @default(false) @map("is_pinned")
  createdById     String   @map("created_by_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @default(now()) @map("updated_at")

  grade           Grade?   @relation(fields: [gradeId], references: [id], onDelete: SetNull)
  createdBy       User     @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@map("notices")
}
// ─── HOMEWORK / ASSIGNMENTS ─────────────────────────────

model Homework {
  id              String   @id @default(cuid())
  title           String
  description     String?
  subjectId       String   @map("subject_id")
  sectionId       String   @map("section_id")
  academicYearId  String   @map("academic_year_id")
  assignedById    String   @map("assigned_by_id")
  assignedDate    String   @map("assigned_date")    // BS date
  dueDate         String?  @map("due_date")          // BS date
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @default(now()) @map("updated_at")

  subject      Subject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  section      Section      @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  academicYear AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  assignedBy   User         @relation(fields: [assignedById], references: [id], onDelete: Cascade)

  @@map("homeworks")
}
// ─── ADMISSION ──────────────────────────────────────────

model Admission {
  id              String   @id @default(cuid())
  studentName     String   @map("student_name")
  studentNameNp   String?  @map("student_name_np")
  dateOfBirth     String?  @map("date_of_birth")
  gender          String?
  fatherName      String?  @map("father_name")
  motherName      String?  @map("mother_name")
  guardianName    String?  @map("guardian_name")
  guardianPhone   String?  @map("guardian_phone")
  address         String?
  previousSchool  String?  @map("previous_school")
  applyingForGradeId String @map("applying_for_grade_id")
  academicYearId  String   @map("academic_year_id")
  status          String   @default("PENDING")  // PENDING, APPROVED, REJECTED, ENROLLED
  remarks         String?
  appliedDate     String   @map("applied_date")  // BS date
  reviewedById    String?  @map("reviewed_by_id")
  reviewedDate    String?  @map("reviewed_date")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @default(now()) @map("updated_at")

  applyingForGrade Grade        @relation(fields: [applyingForGradeId], references: [id], onDelete: Cascade)
  academicYear     AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  reviewedBy       User?        @relation(fields: [reviewedById], references: [id], onDelete: SetNull)

  @@map("admissions")
}
// ─── PARENT-STUDENT LINK ────────────────────────────────

model ParentStudent {
  id          String   @id @default(cuid())
  parentId    String   @map("parent_id")
  studentId   String   @map("student_id")
  relationship String? // FATHER, MOTHER, GUARDIAN
  createdAt   DateTime @default(now()) @map("created_at")

  parent      User     @relation("ParentLinks", fields: [parentId], references: [id], onDelete: Cascade)
  student     Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  

  @@unique([parentId, studentId])
  @@map("parent_students")
}
// ─── RECEIPT COUNTER ────────────────────────────────────

model ReceiptCounter {
  schoolId  String @id @map("school_id")
  lastValue Int    @default(0) @map("last_value")

  school    School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@map("receipt_counters")
}

// ─── AUDIT LOG ──────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  userId     String   @map("user_id")
  action     String                        // e.g. PAYMENT_CREATED, PAYMENT_DELETED
  entity     String                        // e.g. FeePayment
  entityId   String   @map("entity_id")   // id of the affected record
  detail     Json?                         // extra info: amount, receiptNumber, etc.
  ipAddress  String?  @map("ip_address")
  createdAt  DateTime @default(now()) @map("created_at")

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("audit_logs")
}
