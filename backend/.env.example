# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/nepali_report_card?schema=public"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Server
PORT=4000
NODE_ENV=development

# Frontend URL (for CORS)
FRONTEND_URL="http://localhost:3000"

# Default password assigned to auto-created student accounts (change in production)
DEFAULT_STUDENT_PASSWORD="student123"
